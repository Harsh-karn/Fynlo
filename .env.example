# Fynlo Environment Variables Example Configuration
# Copy this file to '.env' and fill in the values for your local environment

# App Environment (development, staging, production)
ENVIRONMENT=development

# Database Configuration
# For local development, you can use SQLite or local PostgreSQL
DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fynlo

# JWT / Security Settings
# Generate a strong key using: openssl rand -hex 32
SECRET_KEY=your-jwt-secret-256-bit
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cache / Queue Broker (Celery & Redis)
REDIS_URL=redis://localhost:6379/0

# Optional Features / Services
# Cloudinary (if statement storage is configured)
CLOUDINARY_URL=

# Frontend Application Origin (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# NextAuth Configuration
# URL of your Next.js application
NEXTAUTH_URL=http://localhost:3000
# Generate a secret using: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-32-chars

# Transactional Email Server Settings (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Gemini API Key for transaction categorization
# Get one from Google AI Studio
GEMINI_API_KEY=
